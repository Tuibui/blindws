# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# --- venv ---
venv/
env/
.venv/

# --- Third-party clones (regeneratable) ---
pytorch-YOLOv4/

# --- CiRA Core artifacts that are useless to us ---
# Encrypted weights cannot be loaded by any standard tool.
dataset_from_cira/datagen_cira/backup/

# --- Generated / large artifacts ---
# Ultralytics-format dataset is regenerated by training/prepare_dataset.py
training/dataset/
# Training output (checkpoints, plots)
training/runs/
# ONNX/blob outputs (regenerated by export.py + tools.luxonis.com)
*.onnx
*.blob
*.engine
# Keep model_from_ciracore/{obj.names,test.cfg,train.weights} as reference
# but don't push large generated onnx
model_from_ciracore/*.onnx

# --- Debug capture (runtime data, not source) ---
debug_capture/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
*.swp
